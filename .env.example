# --- Security Platform Configuration ---

# API Keys (Threat Intelligence)
VIRUSTOTAL_API_KEY=your_virustotal_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# Telegram Bot (Alerts)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Database
DATABASE_URL=postgresql://user:password@db:5432/nginxadmin
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=nginxadmin

# ClickHouse (Logs)
CLICKHOUSE_URL=http://clickhouse:8123

# Agent
AGENT_SOCKET_PATH=/var/run/agent/agent.sock
MANAGED_CONTAINER_NAME=nginx-admin-proxy
